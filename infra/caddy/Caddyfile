# FB-CONT-004 — optional TLS edge (Caddy) in front of the API container.
#
# Map hostnames to 127.0.0.1:
#   127.0.0.1 app.localhost
#
# HTTPS (self-signed via Caddy **internal** CA): publish container :443 as host **8443**.
#   https://app.localhost:8443  → FastAPI + React SPA
#
# Trust: click through browser warning or install Caddy's local root (dev only).
#
# Production: replace hostname with real DNS, remove `tls internal`, Caddy auto-provisions
# Let's Encrypt certs when ports 80/443 are publicly reachable.

{
  admin off
}

https://app.localhost {
  tls internal
  reverse_proxy trading-bot-api:8001
}
