# ── Database URLs ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://trading:trading@localhost:5432/trading
CLICKHOUSE_URL=http://trading:trading@localhost:8123/trading
REDIS_URL=redis://localhost:6379

# ── Event Fabric ───────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Broker API Credentials (never committed — copy to .env and fill in) ───────
COINBASE_API_KEY=
COINBASE_API_SECRET=

ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ── Platform ───────────────────────────────────────────────────────────────────
PLATFORM_PORT=8080
RUST_LOG=info

# ── Risk defaults (overridden by per-user DB config) ──────────────────────────
RISK_MAX_POSITION_USD=10000
RISK_MAX_DAILY_LOSS_USD=500

# ── Phase 7: AI / Vector store / Graph (H-12) ─────────────────────────────────
# OpenAI — required by the embedder service; hard-fails at startup if unset.
OPENAI_API_KEY=

# Milvus vector store (docker-compose: port 19530 for REST v2 API)
MILVUS_HOST=localhost
MILVUS_HTTP_PORT=19530
# Optional: leave blank for Milvus deployments without RBAC enabled.
MILVUS_USERNAME=
MILVUS_PASSWORD=

# TigerGraph capability graph
# TIGERGRAPH_PORT      → REST++ data API (docker-compose maps container 9000 → host 9200)
# TIGERGRAPH_GSQL_PORT → GSQL admin/schema API (container 14240 → host 14240)
TIGERGRAPH_HOST=localhost
TIGERGRAPH_PORT=9200
TIGERGRAPH_GSQL_PORT=14240
TIGERGRAPH_USER=tigergraph
TIGERGRAPH_PASSWORD=tigergraph
TIGERGRAPH_GRAPH=trading

# ── Phase 7: Web scraper (collector-web) ──────────────────────────────────────
# Comma-separated list of HTTPS URLs to scrape (http:// and private IPs rejected).
WEB_SCRAPER_URLS=
# Minimum seconds between requests to the same domain (default 2).
WEB_SCRAPER_RATE_SECS=2
# Seconds between full scrape passes (default 300).
WEB_SCRAPER_POLL_SECS=300
# Full path to the Playwright Node.js binary (optional; enables JS-rendered pages).
PLAYWRIGHT_BIN=
