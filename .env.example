# Copy to `.env` in the repo root. Application settings use the `NM_` prefix (see `app/config/settings.py`).
# pydantic-settings loads `.env` automatically when present.

# --- Alpaca (paper trading) ---
NM_ALPACA_API_KEY=
NM_ALPACA_API_SECRET=

# --- Market data (Kraken public REST + WebSocket) ---
# NM_MARKET_DATA_BAR_INTERVAL_SECONDS=1   # live WS → OHLC roll-up bucket (seconds)
# NM_TRAINING_DATA_GRANULARITY_SECONDS=60   # offline campaign bar size; 1 = use Trades aggregation (slow for long lookbacks)

# --- Coinbase Advanced Trade (live execution only; CDP JWT — not used for market data) ---
# NM_COINBASE_API_KEY=
# NM_COINBASE_API_SECRET=

# --- Risk / control plane ---
# NM_RISK_SIGNING_SECRET=
# NM_CONTROL_PLANE_API_KEY=
# NM_ALLOW_UNSIGNED_EXECUTION=false

# --- Master pipeline (optional) ---
# NM_MODELS_FORECASTER_CHECKPOINT_ID=
# NM_MODELS_FORECASTER_CONFORMAL_STATE_PATH=
# NM_MODELS_FORECASTER_WEIGHTS_PATH=   # NPZ from capture_forecaster_weights_from_seed / training export
# NM_MODELS_FORECASTER_TORCH_PATH=     # forecaster_torch.pt (optional; takes precedence over NPZ for quantiles)
# NM_MODELS_POLICY_MLP_PATH=           # NPZ MultiBranchMLPPolicy.save
# PyTorch forecaster training: auto (CUDA if available) | cpu | cuda | cuda:0
# NM_MODELS_TORCH_DEVICE=auto
# NM_MODELS_ACTIVE_REGISTRY_PATH=   # optional: models/registry/active_model_set.json

# Legacy names like API_KEY / API_SECRET are not read — use NM_* as above.
