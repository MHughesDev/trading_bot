# Copy to `.env` in the repo root. Application settings use the `NM_` prefix (see `app/config/settings.py`).
# pydantic-settings loads `.env` automatically when present.
#
# Operator checklist (venv, Docker, preflight, keys): docs/READY_TO_RUN.MD

# --- Alpaca (paper trading) ---
NM_ALPACA_API_KEY=
NM_ALPACA_API_SECRET=

# --- Market data (Kraken public REST + WebSocket) ---
# NM_MARKET_DATA_BAR_INTERVAL_SECONDS=1   # live WS → OHLC roll-up bucket (seconds)
# NM_TRAINING_DATA_GRANULARITY_SECONDS=60   # offline campaign bar size; 1 = use Trades aggregation (slow for long lookbacks)
#
# Microservices: market_data_service (optional Kraken WS publisher to Redis)
# NM_MARKET_DATA_KRAKEN_WS=false          # true = connect Kraken public WS, publish market.tick.normalized.v1
# NM_MARKET_DATA_SYMBOLS=BTC-USD,ETH-USD  # comma-separated config symbols
# NM_MARKET_DATA_HEARTBEAT_SECONDS=30     # periodic market.heartbeat.v1 when WS mode is on
#
# Microservices: feature_service (parity with live_service rolling bars + FeaturePipeline)
# NM_FEATURE_SERVICE_USE_PIPELINE=true    # false = legacy tick→row scaffold only
# NM_FEATURE_SERVICE_BAR_INTERVAL_SECONDS=1

# --- Coinbase Advanced Trade (live execution only; CDP JWT — not used for market data) ---
# NM_COINBASE_API_KEY=
# NM_COINBASE_API_SECRET=

# Per-asset model manifests (optional; see docs/PER_ASSET_OPERATOR.MD)
# NM_ASSET_MODEL_REGISTRY_DIR=data/asset_model_registry/manifests

# Per-asset init pipeline (Kraken bootstrap → validate → features Parquet; see docs/PER_ASSET_OPERATOR.MD)
# NM_ASSET_INIT_BOOTSTRAP_LOOKBACK_DAYS=14
# NM_ASSET_INIT_BOOTSTRAP_GRANULARITY_SECONDS=60
# NM_ASSET_INIT_ARTIFACTS_DIR=data/asset_init

# --- Risk / control plane ---
# NM_RISK_SIGNING_SECRET=
# NM_CONTROL_PLANE_API_KEY=
# NM_ALLOW_UNSIGNED_EXECUTION=false

# --- QuestDB (optional persistence) ---
# NM_QUESTDB_PERSIST_MICROSERVICE_EVENTS=false   # observability_writer → microservice_events table

# --- Master pipeline (optional) ---
# NM_MODELS_FORECASTER_CHECKPOINT_ID=
# NM_MODELS_FORECASTER_CONFORMAL_STATE_PATH=
# NM_MODELS_FORECASTER_WEIGHTS_PATH=   # NPZ from capture_forecaster_weights_from_seed / training export
# NM_MODELS_FORECASTER_TORCH_PATH=     # forecaster_torch.pt (optional; takes precedence over NPZ for quantiles)
# NM_MODELS_POLICY_MLP_PATH=           # NPZ MultiBranchMLPPolicy.save
# Optional JSON manifest: overrides the above NM_MODELS_* serving paths for keys present (FB-SPEC-06)
# NM_MODELS_ACTIVE_SET_PATH=
# NM_MODELS_ACTIVE_SET_LABEL=            # optional operator label (also readable from manifest "label")
# NM_MODELS_ACTIVE_SET_MANIFEST_VERSION=
# PyTorch forecaster training: auto (CUDA if available) | cpu | cuda | cuda:0
# NM_MODELS_TORCH_DEVICE=auto
# NM_MODELS_ACTIVE_REGISTRY_PATH=   # optional: models/registry/active_model_set.json

# Legacy names like API_KEY / API_SECRET are not read — use NM_* as above.
